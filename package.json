{
  "name": "vampire-survivors-web",
  "version": "1.0.0",
  "description": "Vampire Survivors-like Roguelike survival game built with Phaser.js + TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:gh-pages": "tsc && vite build --mode gh-pages",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run tests/property"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "@capacitor/core": "^5.7.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "fast-check": "^3.19.0",
    "@capacitor/cli": "^5.7.0",
    "terser": "^5.31.0"
  }
}
